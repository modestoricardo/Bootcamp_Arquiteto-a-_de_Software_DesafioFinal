        <mxCell id="legend-content" value="📦 = Pacote Java (package)&#10;📁 = Pasta/Diretório (folder)&#10;📄 = Arquivo (file)&#10;&#10;&lt;b&gt;Padrões de nomenclatura:&lt;/b&gt;&#10;• Pacotes: tudo minúsculo (ex: controller, service)&#10;• Classes: PascalCase (ex: ProdutoController)&#10;• Arquivos de config: camelCase ou kebab-case" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="100" y="1605" width="460" height="145" as="geometry" />
        </mxCell>

