        </mxCell>
        
        <mxCell id="tech-title" value="&lt;b&gt;Stack Tecnológico&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="570" y="1195" width="200" height="30" as="geometry" />
