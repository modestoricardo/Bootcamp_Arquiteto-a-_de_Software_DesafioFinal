        <mxCell id="tech-desc" value="&lt;b&gt;Framework:&lt;/b&gt; Spring Boot 3.x&#10;&lt;b&gt;Linguagem:&lt;/b&gt; Java 17+&#10;&lt;b&gt;Persistência:&lt;/b&gt; Spring Data JPA + Hibernate&#10;&lt;b&gt;Banco de Dados:&lt;/b&gt; H2 Database (em memória)&#10;&lt;b&gt;Documentação:&lt;/b&gt; SpringDoc OpenAPI (Swagger)&#10;&lt;b&gt;Build Tool:&lt;/b&gt; Maven&#10;&lt;b&gt;Servidor:&lt;/b&gt; Tomcat Embedded" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacing=4;" vertex="1" parent="1">
