        </mxCell>

        <mxCell id="pattern-desc" value="&lt;b&gt;Model (Entidade):&lt;/b&gt; Representa os dados e regras de negócio&#10;&lt;b&gt;View (JSON):&lt;/b&gt; Representação dos dados (ResponseEntity)&#10;&lt;b&gt;Controller:&lt;/b&gt; Gerencia requisições e respostas HTTP&#10;&#10;&lt;b&gt;Camadas Adicionais:&lt;/b&gt;&#10;• Service: Lógica de negócio&#10;• Repository: Acesso a dados (persistência)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="100" y="1225" width="390" height="125" as="geometry" />
        </mxCell>

