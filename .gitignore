# ===================================================================
# .gitignore - API REST de Produtos
# ===================================================================

# ===================================================================
# Maven
# ===================================================================
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ===================================================================
# IntelliJ IDEA
# ===================================================================
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/

# ===================================================================
# Eclipse
# ===================================================================
.classpath
.project
.settings/
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib
local.properties
.loadpath
.recommenders

# ===================================================================
# NetBeans
# ===================================================================
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ===================================================================
# VS Code
# ===================================================================
.vscode/
*.code-workspace

# ===================================================================
# Spring Boot
# ===================================================================
spring-boot-devtools.properties

# ===================================================================
# Logs
# ===================================================================
*.log
logs/
log/

# ===================================================================
# OS Files
# ===================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ===================================================================
# Temporary files
# ===================================================================
*.tmp
*.temp
*~

# ===================================================================
# Package Files
# ===================================================================
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ===================================================================
# H2 Database Files (se não estiver em memória)
# ===================================================================
*.db
*.mv.db
*.trace.db

# ===================================================================
# Build artifacts
# ===================================================================
build/
dist/

# ===================================================================
# Compilation files
# ===================================================================
*.class

# ===================================================================
# BlueJ files
# ===================================================================
*.ctxt

# ===================================================================
# Mobile Tools for Java (J2ME)
# ===================================================================
.mtj.tmp/

# ===================================================================
# virtual machine crash logs
# ===================================================================
hs_err_pid*
replay_pid*
